generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  image       String
  category    String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id           String    @id @default(cuid())
  customerName String
  email        String
  address      String
  items        String
  total        Float
  status       String    @default("pending")
  paymentId    String?   @unique  // Razorpay payment_id — prevents duplicate orders
  trackingId   String?
  courier      String?
  createdAt    DateTime  @default(now())
  shippedAt    DateTime?
  deliveredAt  DateTime?
  updatedAt    DateTime  @updatedAt
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  phone     String?
  password  String?
  provider  String   @default("email")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  otps      OTP[]
}

model OTP {
  id        String   @id @default(cuid())
  email     String?
  phone     String?
  code      String
  purpose   String   @default("login")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model Admin {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  // 2FA fields
  totpSecret  String?          // encrypted TOTP secret
  totpEnabled Boolean  @default(false)
  totpVerifiedAt DateTime?
  // Login tracking
  lastLoginAt   DateTime?
  lastLoginIp   String?
  failedAttempts Int     @default(0)
  lockedUntil   DateTime?
  createdAt   DateTime @default(now())
}

// Distributed rate limiting store (DB-backed, works across Vercel instances)
model RateLimit {
  id        String   @id
  count     Int      @default(1)
  resetAt   DateTime
  createdAt DateTime @default(now())

  @@index([resetAt])
}

// Audit log — every admin action recorded
model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "order.update", "product.delete", "admin.login"
  adminId   String?
  ip        String?
  userAgent String?
  payload   String?  // JSON
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

// Idempotency table — prevents Razorpay webhook replays creating duplicate orders
model WebhookEvent {
  id          String   @id              // razorpay payment_id used as idempotency key
  event       String                   // e.g. "payment.captured"
  orderId     String?                  // our Order.id if order was created
  processedAt DateTime @default(now())
  payload     String                   // raw JSON for debugging

  @@index([processedAt])
}
