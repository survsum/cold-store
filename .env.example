# ══════════════════════════════════════════════════════
#  COLD DOG — Environment Variables
#  Copy this to .env for local dev
#  Add all of these to Vercel → Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════

# ── Database (PostgreSQL — get free DB from neon.tech) ──────────────────
# Neon gives you two URLs: DATABASE_URL (pooled) + DIRECT_URL (direct)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Admin ────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@store.com"
ADMIN_PASSWORD="your_secure_admin_password"
ADMIN_SESSION_SECRET="generate_32_char_random_string_here"

# ── User Auth (JWT) ──────────────────────────────────────────────────────
USER_JWT_SECRET="generate_32_char_random_string_here"

# NextAuth (kept for compatibility)
NEXTAUTH_SECRET="generate_32_char_random_string_here"
NEXTAUTH_URL="https://your-domain.vercel.app"

# ── Razorpay ─────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_your_key"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="set_this_in_razorpay_dashboard_webhooks"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_your_key"

# ── Email OTP ────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_FROM="Cold Dog <your@gmail.com>"

# ── Image Uploads (Cloudinary — free at cloudinary.com) ─────────────────
# Create account → Settings → Upload → Add upload preset (unsigned)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_UPLOAD_PRESET="your_unsigned_preset"

# ── Google OAuth (optional) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# ── Upstash Redis (distributed rate limiting — free at upstash.com) ──────────
# Create a Redis database → copy REST URL and token
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_token_here"

# ── Admin 2FA (TOTP — generated via /admin/setup-2fa) ────────────────────────
# Leave blank to disable 2FA. Set after running the setup wizard.
ADMIN_TOTP_SECRET=""
